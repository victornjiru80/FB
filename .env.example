# Copy to .env for local development (never commit .env).

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Production: set to your public URL (used in emails and links)
SITE_URL=http://localhost:8000

# PostgreSQL: use either DATABASE_URL (Render) or POSTGRES_URL
# postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
# DATABASE_URL=
# POSTGRES_URL=

# HTTPS behind a proxy (default True when DEBUG=False)
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000

# Required in production (Django 4+): comma-separated origins, no trailing slash
# CSRF_TRUSTED_ORIGINS=https://your-service.onrender.com

# Email (Mailjet)
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=

# Stripe
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
